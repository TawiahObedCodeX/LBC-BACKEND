# ──────────────────────────────────────────────────────────────
# Church Backend — Environment Variables
# Copy this file to `.env` and fill in real values.
# NEVER commit the real `.env` file to git.
# ──────────────────────────────────────────────────────────────

# Which environment is this? development | test | production
NODE_ENV=development

# Port the API listens on
PORT=5000

# PostgreSQL connection string (Prisma format)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/church_backend

# Redis connection string
# Format: redis://HOST:PORT  (add a password as redis://:PASSWORD@HOST:PORT if your Redis requires one)
REDIS_URL=redis://localhost:6379

# JWT secrets — generate each one separately with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=replace_with_a_long_random_string
JWT_REFRESH_SECRET=replace_with_a_different_long_random_string

# Comma-separated list of frontend origins allowed to call this API
CORS_ALLOWED_ORIGINS=http://localhost:3000

# General API rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Paystack (fill in when you get to the payments module)
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=

# SMTP (fill in when you get to the newsletter module)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
